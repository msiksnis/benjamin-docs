{
  "version": 1,
  "mode": "codebase",
  "docsRoot": "benjamin-docs",
  "focus": "codebase",
  "watch": [
    {
      "label": "database/schema",
      "paths": [
        "**/*.sql",
        "**/migrations/**",
        "**/*.prisma",
        "db/schema.rb",
        "**/database.types.*"
      ],
      "docs": [
        "benjamin-docs/project/brief.md",
        "benjamin-docs/project/roadmap.md",
        "benjamin-docs/handoff/human-brief.md",
        "benjamin-docs/handoff/agent-brief.md",
        "benjamin-docs/engineering/architecture.md",
        "benjamin-docs/engineering/code-map.md",
        "benjamin-docs/releases/changelog.md"
      ]
    },
    {
      "label": "application code",
      "paths": [
        "src/**",
        "skills/**"
      ],
      "docs": [
        "benjamin-docs/project/brief.md",
        "benjamin-docs/project/roadmap.md",
        "benjamin-docs/handoff/human-brief.md",
        "benjamin-docs/handoff/agent-brief.md",
        "benjamin-docs/engineering/architecture.md",
        "benjamin-docs/engineering/code-map.md",
        "benjamin-docs/releases/changelog.md"
      ]
    },
    {
      "label": "tests",
      "paths": [
        "test/**",
        "**/*.test.*"
      ],
      "docs": [
        "benjamin-docs/handoff/agent-brief.md",
        "benjamin-docs/engineering/code-map.md"
      ]
    },
    {
      "label": "configuration/workflow",
      "paths": [
        "package.json",
        "tsconfig*.json",
        ".github/workflows/**",
        "pnpm-workspace.yaml"
      ],
      "docs": [
        "benjamin-docs/project/roadmap.md",
        "benjamin-docs/handoff/agent-brief.md",
        "benjamin-docs/engineering/architecture.md",
        "benjamin-docs/engineering/code-map.md",
        "benjamin-docs/releases/changelog.md"
      ]
    },
    {
      "label": "project memory/status",
      "paths": [
        "README.md",
        "docs/**",
        "tasks/**",
        ".claude/**",
        ".cursor/**",
        "AGENTS.md"
      ],
      "docs": [
        "benjamin-docs/project/brief.md",
        "benjamin-docs/project/roadmap.md",
        "benjamin-docs/project/open-questions.md",
        "benjamin-docs/handoff/human-brief.md",
        "benjamin-docs/handoff/agent-brief.md",
        "benjamin-docs/features/index.md"
      ]
    },
    {
      "label": "feature/freshness-and-lifecycle",
      "paths": [
        "src/**",
        "skills/**",
        "test/**",
        "**/*.test.*",
        "README.md",
        "docs/**",
        ".claude/**",
        ".cursor/**"
      ],
      "docs": [
        "benjamin-docs/features/freshness-and-lifecycle/brief.md",
        "benjamin-docs/features/freshness-and-lifecycle/plan.md",
        "benjamin-docs/features/freshness-and-lifecycle/decisions.md",
        "benjamin-docs/features/freshness-and-lifecycle/handoff.md"
      ]
    },
    {
      "label": "feature/guided-export-workflow",
      "paths": [
        "src/**",
        "app/**",
        "apps/**",
        "lib/**",
        "pages/**",
        "components/**",
        "server/**",
        "api/**",
        "**/*.sql",
        "**/migrations/**",
        "README.md",
        "docs/**",
        ".claude/**",
        ".cursor/**"
      ],
      "docs": [
        "benjamin-docs/features/guided-export-workflow/brief.md",
        "benjamin-docs/features/guided-export-workflow/plan.md",
        "benjamin-docs/features/guided-export-workflow/decisions.md",
        "benjamin-docs/features/guided-export-workflow/handoff.md"
      ]
    }
  ]
}
