{
  "name": "benjamin-docs",
  "version": "0.11.0",
  "description": "Persistent project memory for AI coding agents. Session hooks load it into Claude Code, Codex, and Cursor automatically; drift detection flags docs that fell behind the code.",
  "keywords": [
    "ai",
    "ai-agent",
    "ai-agents",
    "coding-agents",
    "agent-memory",
    "persistent-memory",
    "context-continuity",
    "repo-memory",
    "project-memory",
    "session-hooks",
    "drift-detection",
    "agents",
    "agent-skill",
    "codex",
    "claude",
    "claude-code",
    "cursor",
    "documentation",
    "docs",
    "developer-tools",
    "handoff",
    "context",
    "markdown",
    "cli"
  ],
  "homepage": "https://github.com/msiksnis/benjamin-docs#readme",
  "bugs": {
    "url": "https://github.com/msiksnis/benjamin-docs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msiksnis/benjamin-docs.git"
  },
  "type": "module",
  "bin": {
    "benjamin-docs": "dist/src/cli.js",
    "bd": "dist/src/cli.js"
  },
  "packageManager": "pnpm@11.5.1",
  "files": [
    "dist/src",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test dist/test/**/*.test.js",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm build && pnpm test",
    "release:check": "pnpm check && node dist/src/cli.js validate && npm pack --dry-run",
    "release:github": "node scripts/release-github.mjs release",
    "release:verify-public": "node scripts/release-github.mjs verify",
    "prepublishOnly": "pnpm run release:check"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.3"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
